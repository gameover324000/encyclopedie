<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Espèces — Y — Herbarium</title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400;1,600&family=EB+Garamond:ital,wght@0,400;0,500;1,400&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="../style.css" />
  <style>
    .index-hero {
      text-align: center;
      padding: 4rem 2rem 3rem;
      border-bottom: 1px solid var(--border);
      background:
        radial-gradient(ellipse at 15% 85%, rgba(61,107,74,.06) 0%, transparent 55%),
        radial-gradient(ellipse at 85% 15%, rgba(143,104,32,.05) 0%, transparent 55%);
    }
    .index-hero .hero-tag {
      display: inline-block;
      font-size: .72rem; letter-spacing: .22em; text-transform: uppercase;
      color: var(--gold); border: 1px solid var(--gold-light);
      padding: .3rem 1rem; margin-bottom: 1.4rem;
    }
    .index-hero h1 {
      font-family: 'Playfair Display', serif;
      font-size: clamp(2.2rem,5vw,3.8rem); font-weight: 600;
      line-height: 1.1; color: var(--ink);
    }
    .index-hero h1 em { color: var(--accent); font-style: italic; }
    .index-hero p {
      margin: 1rem auto 0; max-width: 480px;
      font-size: 1.05rem; color: var(--ink-muted);
      font-style: italic; line-height: 1.65;
    }
    .ornament {
      margin: 1.8rem auto;
      display: flex; align-items: center; justify-content: center;
      gap: .8rem; color: var(--gold); opacity: .5;
    }
    .ornament::before, .ornament::after {
      content: ''; display: block;
      width: 55px; height: 1px; background: var(--gold);
    }
    .index-stats {
      display: inline-flex; gap: 2.5rem;
      font-size: .88rem; color: var(--ink-muted); letter-spacing: .04em;
    }
    .index-stats span strong {
      display: block;
      font-family: 'Playfair Display', serif;
      font-size: 1.6rem; color: var(--ink); letter-spacing: 0;
    }
    /* Grille des lettres */
    .grille-lettres {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
      gap: 1rem;
      max-width: 900px;
      margin: 2.5rem auto 0;
      padding: 0 1rem;
    }
    .lettre-carte {
      display: flex; flex-direction: column; align-items: center;
      padding: 1.5rem 1rem;
      border: 1px solid var(--border);
      background: #fff9ee;
      text-decoration: none;
      transition: transform .2s, box-shadow .2s;
    }
    .lettre-carte:not(.disabled):hover {
      transform: translateY(-4px);
      box-shadow: 0 8px 24px rgba(30,18,8,.1);
      background: var(--accent-light);
    }
    .lettre-carte.disabled { opacity: .35; cursor: default; }
    .carte-lettre {
      font-family: 'Playfair Display', serif;
      font-size: 2.8rem; font-style: italic;
      color: var(--accent); line-height: 1;
      margin-bottom: .5rem;
    }
    .lettre-carte.disabled .carte-lettre { color: var(--ink-muted); }
    .carte-nb {
      font-size: .78rem; letter-spacing: .08em;
      text-transform: uppercase; color: var(--ink-muted);
    }
    /* Barre alpha */
    .alpha-bar {
      position: sticky; top: 58px; z-index: 200;
      background: rgba(244,236,213,.97);
      border-bottom: 1px solid var(--border);
      padding: .6rem 1.5rem; text-align: center;
      backdrop-filter: blur(4px);
    }
    .alpha-btn {
      display: inline-block;
      width: 32px; height: 32px; line-height: 32px; text-align: center;
      font-family: 'Playfair Display', serif; font-size: .95rem;
      color: var(--ink-light); text-decoration: none;
      border-radius: 3px; margin: 2px 1px;
      transition: background .18s, color .18s;
    }
    .alpha-btn:hover, .alpha-btn.active {
      background: var(--accent); color: var(--parch);
    }
    /* Contenu */
    main { max-width: 1300px; margin: 0 auto; padding: 2.5rem 2rem 5rem; }
    .letter-section {
      margin-bottom: 3rem;
      border: 1px solid var(--border);
      background: #fff9ee; overflow: hidden;
    }
    .letter-header {
      display: flex; align-items: baseline; justify-content: space-between;
      padding: .9rem 1.8rem;
      background: linear-gradient(90deg, var(--accent-dark), var(--accent));
    }
    .letter-glyph {
      font-family: 'Playfair Display', serif; font-size: 2.2rem;
      font-style: italic; color: var(--parch); line-height: 1;
    }
    .letter-count {
      font-size: .78rem; letter-spacing: .12em; text-transform: uppercase;
      color: rgba(244,236,213,.65);
    }
    .letter-columns {
      display: grid; grid-template-columns: 1fr 1fr;
      padding: 1rem; gap: 0;
    }
    .letter-col { padding: 0 1rem; }
    .letter-col:first-child { border-right: 1px solid var(--border); }
    .plant-list { list-style: none; }
    .plant-list li { border-bottom: 1px solid rgba(74,51,32,.06); }
    .plant-list li:last-child { border-bottom: none; }
    .plant-link {
      display: block; padding: .38rem .6rem;
      font-style: italic; font-size: .9rem;
      color: var(--ink-light); text-decoration: none;
      transition: background .15s, color .15s, padding-left .15s;
      border-radius: 2px;
    }
    .plant-link:hover {
      background: var(--accent-light);
      color: var(--accent-dark); padding-left: 1rem;
    }
    .back-top {
      position: fixed; bottom: 2rem; right: 2rem;
      width: 42px; height: 42px;
      background: var(--accent); color: var(--parch);
      border: none; border-radius: 50%; font-size: 1.1rem;
      cursor: pointer; display: flex; align-items: center; justify-content: center;
      box-shadow: 0 3px 12px rgba(30,18,8,.18);
      text-decoration: none;
      transition: background .2s, transform .2s; z-index: 400;
    }
    .back-top:hover { background: var(--accent-dark); transform: translateY(-3px); }
    @media (max-width: 700px) {
      .letter-columns { grid-template-columns: 1fr; }
      .letter-col:first-child { border-right: none; border-bottom: 1px solid var(--border); }
      .alpha-btn { width: 26px; height: 26px; line-height: 26px; font-size: .8rem; }
    }
  </style>
</head>
